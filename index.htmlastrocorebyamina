<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ASTROCORE by Amina</title>
    <style>
        body { margin: 0; background: #000; color: white; font-family: 'Segoe UI', sans-serif; overflow: hidden; }
        
        /* Main UI */
        #ui-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; display: flex; flex-direction: column; justify-content: space-between; }
        
        header { padding: 30px; background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent); pointer-events: auto; }
        .main-title { font-size: 28px; font-weight: bold; letter-spacing: 4px; color: #6366f1; margin: 0; }
        .subtitle { font-size: 12px; color: #aaa; letter-spacing: 2px; }

        /* Dashboard - Big to Small */
        .dashboard { padding: 20px; background: rgba(10,10,10,0.8); backdrop-filter: blur(10px); display: flex; flex-wrap: wrap; gap: 10px; pointer-events: auto; border-top: 1px solid #333; }
        
        button { background: transparent; border: 1px solid #444; color: white; padding: 12px 18px; cursor: pointer; border-radius: 5px; transition: all 0.3s; font-size: 11px; text-transform: uppercase; }
        button:hover { background: #6366f1; border-color: #6366f1; transform: translateY(-3px); }

        /* Planet Info Card */
        .info-card { position: absolute; right: 30px; top: 100px; width: 320px; background: rgba(0,0,0,0.85); border: 1px solid #6366f1; padding: 25px; border-radius: 15px; pointer-events: auto; display: none; box-shadow: 0 0 20px rgba(99, 102, 241, 0.3); }
        
        /* Sun-Earth-Moon Study Section */
        .study-box { position: absolute; bottom: 120px; left: 30px; width: 350px; background: rgba(15,15,20,0.9); padding: 20px; border-radius: 12px; font-size: 13px; pointer-events: auto; border: 1px solid #222; }
        
